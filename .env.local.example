# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (서버 사이드 전용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Posty Sync (server-only, do not prefix with NEXT_PUBLIC_)
POSTY_SYNC_API_BASE_URL=https://your-posty-app.example.com
LINKKO_POSTY_SYNC_SECRET=your-linkko-to-posty-sync-secret
POSTY_SYNC_DISPATCH_SECRET=your-dispatch-trigger-secret
